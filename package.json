{
  "name": "lambda-delivery",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/ tests/",
    "test:unit": "jest tests/unit/ --coverage",
    "coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":60}}'",
    "security:check": "grep -rn 'AKIA\\|aws_secret\\|password\\s*=' --include='*.js' src/ && exit 1 || echo 'OK'",
    "compile": "esbuild src/handler.ts --bundle --platform=node --outdir=dist --format=cjs",
    "build": "npm run compile && bash scripts/package-lambda.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interoperabilidad-sistema-salud/delivery-lambda.git"
  },
  "keywords": [],
